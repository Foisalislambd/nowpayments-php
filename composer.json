{
    "name": "foisalislambd/nowpayments-php",
    "version": "1.0.3",
    "description": "Full-featured PHP SDK for NOWPayments cryptocurrency payment API",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Foisalislambd",
            "url": "https://github.com/Foisalislambd"
        }
    ],
    "keywords": [
        "nowpayments",
        "crypto",
        "cryptocurrency",
        "bitcoin",
        "ethereum",
        "payment",
        "payment-gateway",
        "crypto-payments",
        "payments-api"
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "NowPayments\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NowPayments\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
